{
  "name": "main-client",
  "version": "1.0.0",
  "description": "Main Client Application",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://example.com",
  "scripts": {
    "dev": "chcp 65001 && electron-vite dev --config electron.vite.config.mjs",
    "build": "electron-vite build --config electron.vite.config.mjs",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "dev:web": "vite --config vite.config.web.mjs --open",
    "build:web": "vite build --config vite.config.web.mjs"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "device-sdk": "^1.0.0",
    "electron-updater": "^6.1.7",
    "koffi": "^2.9.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vueuse/core": "^14.1.0",
    "ant-design-vue": "^4.2.6",
    "electron": "^40.0.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^5.0.0",
    "element-plus": "^2.13.1",
    "pinia": "^3.0.4",
    "postcss-pxtorem": "^6.1.0",
    "sass": "^1.97.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^5.0.0",
    "vue": "^3.4.0",
    "vue-router": "^4.6.4"
  }
}
